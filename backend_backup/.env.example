# Server Configuration
PORT=3001

# Fabric Network Configuration (AWS AMB or Local)
MSP_ID=Org1MSP
CHANNEL_NAME=organchannel
CHAINCODE_NAME=organchain

# Peer Connection (Local defaults provided)
PEER_ENDPOINT=localhost:7051
PEER_HOST_ALIAS=peer0.org1.example.com

# Crypto Material Paths (relative to backend directory)
# For AMB, these should point to the certificates exported from the AMB CA
CERT_PATH=../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/users/User1@org1.example.com/msp/signcerts/cert.pem
KEY_PATH=../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/users/User1@org1.example.com/msp/keystore/priv_sk
TLS_CERT_PATH=../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/peers/peer0.org1.example.com/tls/ca.crt

# IPFS Configuration
# For Production, use Web3.Storage or another remote provider
# WEB3_STORAGE_TOKEN=your_token_here
IPFS_API=http://127.0.0.1:5001
